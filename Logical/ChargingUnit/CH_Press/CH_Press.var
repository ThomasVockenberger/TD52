	bRelMon_P2s_A : BOOL := 0; (*Release monitoring charge pressure p2' A*)
	bRelMon_P2s_B : BOOL := 0; (*Release monitoring charge pressure p2' B*)
	bRelMon_P2_A : BOOL := 0; (*Release monitoring charge pressure p2 A*)
	bRelMon_P2_B : BOOL := 0; (*Release monitoring charge pressure p2 B*)
	xTON_200msTick : TON := (0); (*FuB*)
	xTON_ErrMs : TON := (0); (*FuB*)
	xTON_RelMon_P1HP : TON := (0); (*FuB*)
	xTON_RelMon_P1HP_A : TON := (0); (*FuB*)
	xTON_RelMon_P1HP_B : TON := (0); (*FuB*)
	xTON_RelMon_P1LP_A : TON := (0); (*FuB*)
	xTON_RelMon_P1LP_B : TON := (0); (*FuB*)
	xTON_RelMon_P2 : TON := (0); (*FuB*)
	xTON_RelMon_P2bFA : TON := (0); (*FuB*)
	xTON_RelMon_P2HP : TON := (0); (*FuB*)
	xTON_RelMon_P2HP_A : TON := (0); (*FuB*)
	xTON_RelMon_P2HP_B : TON := (0); (*FuB*)
