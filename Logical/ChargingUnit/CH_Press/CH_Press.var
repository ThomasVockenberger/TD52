	bRelMon_P1HP_A : BOOL := 0; (*Release monitoring charge pressure before high pressure TC A*)
	bRelMon_P1HP_B : BOOL := 0; (*Release monitoring charge pressure before high pressure TC B*)
	bRelMon_P1LP_A : BOOL := 0; (*Release monitoring charge pressure before  low pressure TC A*)
	bRelMon_P1LP_B : BOOL := 0; (*Release monitoring charge pressure before  low pressure TC B*)
	bRelMon_P2 : BOOL := 0; (*Release monitoring charge pressure p2*)
