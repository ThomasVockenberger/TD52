	xTON_RelMon_P2_B : TON := (0); (*FuB*)
	xTON_1sTick : TON := (0); (*Release monitoring for charging pressures in standstill*)
	rPr_Ch_Max : REAL := 0.0; (*Maximum value for a plausible pressure in standstill [bar]*)
	rPr_Ch_Min : REAL := 0.0; (*Minimum value for a plausible pressure in standstill [bar]*)
	rPr_Ch_devMax : REAL := 0.0; (*Maximal deviation for a not plausible pressure in standstill [bar]*)
	rPr_Ch_Ok_medVal : REAL := 0.0; (*Median value from array of available charge pressures [bar]*)
	i : USINT := 0; (*Temporary index*)
	j : USINT := 0; (*Temporary index*)
	tPr_Ch_Tmp : Pr_Ch := (0); (*Temporary charge pressure*)
	tPr_Ch_Out : ARRAY[0..17] OF Pr_Ch := [18((0))]; (*Not plausible charge pressures array current cycle*)
	tTmp_Pr_Ch_rest : ARRAY[0..17] OF Pr_Ch := [18((0))]; (*Temporary not plausible charge pressures array*)
	tPr_Ch : ARRAY[0..17] OF Pr_Ch := [18((0))]; (*All possible charge pressures array*)
	tPr_Ch_Ok : ARRAY[0..17] OF Pr_Ch := [18((0))]; (*Available charge pressures array*)
	iPr_Ch_lgt : USINT := 0; (*Array length of all possible charge pressures*)
	iTmp_Pr_Ch_Out_lgt : USINT := 0; (*Array length of temporary not plausible charge pressures*)
