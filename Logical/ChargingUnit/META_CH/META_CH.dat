"	<DEPENDENCY MODULE='PB' VERSION='04.00.00.00' />"
"	<DEPENDENCY MODULE='HA' VERSION='04.05.00.00' />"
"	<DEPENDENCY MODULE='IG' VERSION='04.00.00.00' />"
"	<DEPENDENCY MODULE='OP' VERSION='04.00.00.00' />"
"	<DEPENDENCY MODULE='GT' VERSION='04.00.00.00' />"
"	<DEPENDENCY MODULE='EC' VERSION='04.04.00.00' />"
"	<DEPENDENCY MODULE='EG' VERSION='04.02.00.00' />"
"	<DEPENDENCY MODULE='CU' VERSION='04.06.00.00' />"    	;corrected for SW download via HMI
"   <DEPENDENCY VISVERSION='02.13.00.00' />"				;Dependencies Visualization
"</DEPENDENCIES>"
;
; Module function description  
"<MODULEFUNCTION>" ;<!-- short overview documentation of module function; add reference to detailed information, if available-->
"	<General>	"
"	Monitoring of the charge signals "
"	</General>	"
""
"	<F1 Name='turbocharger speed' LastModified='04.00.00.00'>"
"	Turbocharger speed and signal monitoring. In case of failure -> power reduction	"
"	Monitoring of speed deviation "
"	</F1>"
"	<F2 Name='charge temperature' LastModified='04.00.00.00'>"
"	Charge temperature and signal monitoring. In case of failure -> power reduction	"
"	Monitoring of charge temperature inclination and rate of change "
"	</F2>"
"	<F3 Name='Charge pressure' LastModified='04.00.00.00'>"
"	Charge pressure and signal monitoring. 	"
"	Monitoring of charge pressure deviation"
"	</F3>"
"	<F4 Name='Charge temperature' LastModified='04.01.00.00'>"
"	Changed activation of charge temperature maximum monitoring with island or parallel mode "
"	If engine speed = 0 and no measurement failure -> TC speed is set to 0 "
"	</F4>"
"	<F5 Name='Charge temperature' LastModified='04.02.00.00'>"
"	Provide filtered and unfiltered average charge temperature and average charge pressure to other modules"
"	</F5>"
"	<F6 Name='Sensor package' LastModified='04.04.00.00'>"
"	CM&U sensor package added; airfilter diff. pressure"
"	TC speed deviation function changed"
"	</F6>"
"	<F7 Name='Charging modifications' LastModified='04.07.01.00'>"
"	Calculation of difference pressure adjusted"
"	MsErr now also active with operation mode selector switch in OFF mode"
"	Detection of low-pressure TC exist changed"
"	Air filter difference pressure - consideration of the dynamic pressure component in case of no pitot tube"
"	reduced perm file write interval to avoid CF card wear down, bu1"
"	</F7>"
"	<F8 Name='TC speed modifications' LastModified='04.10.00.00'>"
"	2x out-interface for interpolated TC speed max limit"
"	Use intake air temperature if T1HP is not available"
"	BugFix: Timer & other FuB's"
"	</F8>"
"	<F9 Name='Charging modifications' LastModified='04.12.00.00'>"
"	Extrapolation of TC speed limit"
"	Added forwarding of pressure maximum values to other SW modules"
"	Deleted T1 maximum monitoring / Added calculation and monitoring of T2 max"
"	Deleted 2223, 2317, 2324, 2412, 2478, 2533 / Added 2368-2370, 9370"
"	</F9>"
"	<F10 Name='Boost pressure plausibility check' LastModified='04.14.00.00'>"
"	Pressure signals plausibility check during standstill"
"	Added 9399"
"	</F10>"
""
"	<Info>"
"	Please enter additional module info here.	"
"	</Info>"
""
"	<Customized LastModified='04.00.00.00'>	"
"	- Nothing "
"	</Customized>	"	
""							
"</MODULEFUNCTION>"
;
"</META>"