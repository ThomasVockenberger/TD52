"<META>"
;
; Module ID
"<MODUL>CU</MODUL>"
;
; Module Version (xx.yy.zz.cc) 
"<VERSION>04.25.00.03</VERSION>"
;
; Module Basisupdate Version BU (00-99)
"<BASISUPDATE_VERSION>00</BASISUPDATE_VERSION>"

; Optional: specify order number for limitated module usage
"<ORDER>DT52</ORDER>" ;<!--(optional, wenn nicht vorhanden dann für alle Aufträge gültig)-->
;
; Parameter Check (Name:=aAbcdef; MIN:=xxx; MAX:=yyy;)
"<PARAMETER_CHK>"
"	<PARA1 Name='iEng_Motortype' MIN='208' MAX='1920' />"
"	<PARA2 Name='rN_EngStart_LimHi' MIN='50.0' MAX='2200.0' />"
"	<PARA3></PARA3>"
"	<PARA4></PARA4>"
"	<PARA5></PARA5>"
"</PARAMETER_CHK>"
;
; Statement, if engine operation is also allowed without this module (FALSE) or if this modules parameter check passing is mandatory (TRUE)
"<MANDATORYMODULE>FALSE</MANDATORYMODULE>"
;
; Permanent Datamodule Filenames<!-- state filename only, without extension; use e.g. for counter information storage-->
