; Module function description  
"<MODULEFUNCTION>" ;<!-- short overview documentation of module function; add reference to detailed information, if available-->
"	<General>	"
"	Collection of overall alarms "
"	</General>	"
""
"	<F1 Name='Perm datamodule moved from SYS- to USERROM' LastModified='04.01.01.00'>"
"	</F1>"
"	<F2 Name='barometric pressure' LastModified='04.02.00.00'>"
"	barometric pressure added "
"	main and conrod bearing temperature monitoring added"
"	alarm 3396 added "
"	</F2>"
"	<F3 Name='bearing and slow down time' LastModified='04.03.00.00'>"
"	MIN, MAX, AVG for bearing temperature "
"	calibration and parametrization; read signal strength"
"	SDT bugfix --> speed gradient monitoring only if speed > 80rpm "
"	</F3>"
"	<F4 Name='bearing update / idle friction' LastModified='04.04.00.00'>"
"	W2790, B2904 and B2905 added; A3378 changed to W2794"
"	Conrod CANQueue, low load and fault tolerant mode added --> Specification (d)"
"	idle friction monitoring added"
"	emergency stop push button identification added"
"	</F4>"
"	<F5 Name='bearing update / idle friction' LastModified='04.05.00.00'>"
"	Update bearing software to Specification version (e)"
"	</F5>"
"	<F6 Name='bearing update' LastModified='04.05.02.00'>"
"	Update bearing software to Specification version (f)"
"	</F6>"
"	<F7 Name='bugfix update' LastModified='04.07.01.00'>"
"	Bugfix: conrod: power was compared to 30 instead of 0.3"
"	speed gradient monitoring only if speed >= 130rpm"
"	reduced perm file write interval to avoid CF card wear down, bu1"
"	</F7>"
"	<F8 Name='slow-down time update' LastModified='04.09.00.00'>"
"	Extrapolation between 15% and 5% nominal speed added, correction over cooling water temperature added, plausibility of the speed gradient modified"
"	</F8>"
"	<F9 Name='BugFix' LastModified='04.10.00.00'>"
"	Bugfix: Timer & other FuB's"
"	Bugfix: engine running without demand in island operation"
"	WinMOD simulation included"
"	</F9>"
"	<F10 Name='New feature' LastModified='04.11.00.00'>"
"	Vibration monitoring for engine and generator added"
"	</F10>"
""
