	bPowerSetpointLimit : BOOL;
	bTecJetOn : BOOL; (* TRUE=gas inject valves are active *)
	count : INT := 0;
	count_st : INT := 0;
	count1 : INT := 0; (* Klappensimulation *)
	count2 : INT := 0; (* Klappensimulation *)
	FA_CONV_1 : WDtoBIT;
	FA_CONV_2 : WDtoBIT;
	FA_GAS1_2 : GR_MAXR;
