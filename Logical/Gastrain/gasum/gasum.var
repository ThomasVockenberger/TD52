	GASSTR_1 : BOOL := 0; (* Anwahl Gasstrecke 1 *)
	GASSTR_2 : BOOL := 0; (* Anwahl Gasstrecke 2 *)
	GASV1 : BOOL := 0; (* Gasventil 1 *)
	GASV2 : BOOL := 0; (* Gasventil 2 *)
	GCB_ON : BOOL := FALSE; (*Generatorschalter EIN (TK#3 synchron)*)
