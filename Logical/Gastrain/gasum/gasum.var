	GU31_2 : BOOL := 0; (* Schrittkettenmerker *)
	GU32_0 : BOOL := 0; (* Schrittkettenmerker *)
	GU32_1 : BOOL := 0; (* Schrittkettenmerker *)
	GU32_2 : BOOL := 0; (* Schrittkettenmerker *)
	GUI_0 : BOOL := 0; (* Schrittkettenmerker *)
