; Module function description  
"<MODULEFUNCTION>" ;<!-- short overview documentation of module function; add reference to detailed information, if available-->
"	<General>	"
"   Static Gridcode management"
"	</General>	"
""
"	<F1 Name='Read curves for static GridCode' LastModified='4.00.0.0'>"
"	Read curves for: cos (phi) = f (P),PFC/RMC, Q =f(U),cos(phi)= f(U)   "
"	</F1>"
"	<F2 Name='voltage control' LastModified='4.00.0.0'>"
"	setpoint for reactive power, calculate cos(phi), reactive power limitation, etc. 	"
"	</F2>"
"	<F3 Name=' frequency control' LastModified='4.00.0.0'>"
"   Power setpoint,power limitation, RMC, PFC  	"
"	</F3>"
"	<F4 Name=' alarm management' LastModified='4.00.0.0'>"
"   Msgs for Gridcode 	"
"	</F4>"
"	<F5 Name=' frequency control' LastModified='4.00.4.0'>"
"   offset related to power setpoint at beginning of event 	"
"	</F5>"
"	<F6 Name=' frequency/voltage control' LastModified='4.03.0.0'>"
"   complete re-check of all functions 	"
"	</F6>"""
"	<Info>"
"	V4.04.00.00 Hinzufügen von CustAnaIn[2].Goodqual zu A3385	"
"   V4.04.00.00 operational messages for frequency control"
"   V4.04.00.00 additional update to frequency control "
"	V4.05.00.00	Q func and P func update "
"	V4.06.00.00	Signal loss functions added "
"   V4.07.00.00 External signals from EVU, FSM/LFSM figure "
"	</Info>"
""
"	<Customized LastModified='4.00.0.0'>	"
"	- Nothing "
"	</Customized>	"	
""							
"</MODULEFUNCTION>"
;
"</META>"
