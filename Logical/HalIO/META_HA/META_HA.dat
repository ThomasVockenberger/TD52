"	<DEPENDENCY MODULE='GT' VERSION='04.10.00.00' />"
"	<DEPENDENCY MODULE='HC' VERSION='04.14.00.00' />" 
"	<DEPENDENCY MODULE='IC' VERSION='04.05.00.00' />"
"	<DEPENDENCY MODULE='IG' VERSION='04.00.00.00' />"
"	<DEPENDENCY MODULE='KL' VERSION='04.05.00.00' />"
"	<DEPENDENCY MODULE='KN' VERSION='04.01.00.00' />"
"	<DEPENDENCY MODULE='MO' VERSION='04.05.00.00' />" 
"	<DEPENDENCY MODULE='OP' VERSION='04.04.00.00' />"
"	<DEPENDENCY MODULE='PB' VERSION='04.03.00.00' />"
