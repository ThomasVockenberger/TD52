; Instructions for use:
; --------------------
; make only changes at the version numbers
; watch out for proper "" and <> </> marks and use := and = on the right places!
;
; Outstandings:
; ------------
; datamodule syntax checker 
; (caution: syntax errors here may cause plc runtime errors!)
;
; *******************************************************************************
;
"<META>"
;
; Module ID
"<MODUL>HA</MODUL>"
;
; Module Version (xx.yy.zz.cc) 
"<VERSION>04.25.00.00</VERSION>"
;
; Module Basisupdate Version BU (00-99)
"<BASISUPDATE_VERSION>00</BASISUPDATE_VERSION>"
;
; Specify order number
"<ORDER>DT52</ORDER>"  				;<!--PLEASE FILL IN ORDER ID (HAL_IO is allways customized)-->
;
; Specify engine type
"<ENGINE_TYPE>624</ENGINE_TYPE>"	;<!--PLEASE FILL IN ENGINE TYPE-->
;
; Specify engine version
"<ENGINE_VERSION>L3785</ENGINE_VERSION>" ;<!--PLEASE FILL IN ENGINE VERSION-->
;
; Parameter Check <PARAn Name='aAbcdef' MIN='xxx' MAX='yyy' />  (watch for correct spacings and apostrophs!)
"<PARAMETER_CHK>"
"	<PARA1 Name='rPr_ECWScalMax' MIN='2.0' MAX='20.0' />"
"	<PARA2 Name='rPr_EngLubOilScalMax' MIN='5.0' MAX='20.0' />"
"	<PARA3 Name='rU_Gen_Nom[1]' MIN='70' MAX='65000' />"
"	<PARA4 Name='rF_Nom[1]' MIN='48.0' MAX='62.0' />"
"	<PARA5 />"
"</PARAMETER_CHK>"
;
; Statement, that this modules parameter check passing is mandatory (HA is allways mandatory, so other statements than TRUE here in this module are not possible)
"<MANDATORYMODULE>TRUE</MANDATORYMODULE>"
;
; Permanent Datamodule Filenames<!-- enter filenames for counter and INTERNAL parameter only; filename without extention-->
"<DATAMODULES>" ;<!-- optional; mehrere DATAMODULES erlaubt-->
"	<DATAMODULE>par_HA</DATAMODULE>"
"</DATAMODULES>"
;
; Dependencies Modules (MMxx.yy.zz.cc)
"<DEPENDENCIES>"
"	<DEPENDENCY MODULE='AB' VERSION='04.00.00.00' />"
"	<DEPENDENCY MODULE='AG' VERSION='04.14.00.00' />"
