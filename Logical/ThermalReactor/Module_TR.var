VAR
	bCtrl_ThR_CInc : BOOL; (*OldName: GAS_PLUS*)
	bCtrl_ThR_CDec : BOOL; (*OldName: GAS_MINUS*)
	bGnlWarning : BOOL; (*General warning*)
	bGnlTrip3 : BOOL; (*General trip*)
	bGnlTrip2 : BOOL; (*General trip*)
	bGnlTrip1 : BOOL; (*General trip*)
	bGnlTrip : BOOL; (*General trip*)
	Limit_Pinc : REAL; (* Limit value for load increase *)
	TimeSlot_Pinc : TIME; (* Time slot for monitoring any load increase *)
	xOpMode : OpMode; (*Used to determine the OpState of the engine*)
	bThR_Rel : BOOL; (* Thermal Reactor Release *)
	set_PT_KL_Pinc : BOOL := FALSE; (*set flap interval load increase*)
	FG_HEIZG_moduleTR : BOOL; (* Reaktor el. Heizung Ein *)
	bNoInitDetected : BOOL; (*always true, except 1cycle on init up*)
