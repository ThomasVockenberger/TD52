	RM_KL_END_AUS : BOOL;
	RM_KL_END_EIN : BOOL;
	KL_AUS_M_S : BOOL;
	KL_EIN_M_S : BOOL;
	xTRA01M : SR;
	bThR_RelTest : BOOL; (*!! Release thermoreactor for testing purpose only*)
	bThR_Failure : BOOL := 0; (* Thermoreactor failure *)
	bThR_elHeating : BOOL; (*Thermal reactor electrical heating ON*)
	bThr_AuxGasCompressor_Fault : BOOL;  (* Th.Reactor warning - auxiliary gas compressor fault *)
	bThr_AuxGasPr_PcheckFail : BOOL;  (* Th.Reactor warning - implausible auxiliary gas pressure before/after control valve *)
	bThR2_DPr_Hi : BOOL; (* Th.Reactor warning - differential pressure maximum - ThR2 *)
	bThR2_EH_gr1_T_blocked : BOOL; (* Th.Reactor electrical heating system - ThR2 - blocked status of heating element group 1 *)
	bThR2_EH_gr2_T_blocked : BOOL; (* Th.Reactor electrical heating system - ThR2 - blocked status of heating element group 2 *)
	bThR2_EH_gr3_T_blocked : BOOL; (* Th.Reactor electrical heating system - ThR2 - blocked status of heating element group 3 *)
	bThR2_EH_gr4_T_blocked : BOOL; (* Th.Reactor electrical heating system - ThR2 - blocked status of heating element group 4 *)
	bThR2_EH_gr5_T_blocked : BOOL; (* Th.Reactor electrical heating system - ThR2 - blocked status of heating element group 5 *)
	bThr2_AuxGasValve_fault : BOOL; (* Th.Reactor warning - auxiliary gas solenoid valve fault - ThR2 *)
	bThR2out_SCRin_DPr_Hi : BOOL; (* Exhaust aftertreatment warning - Thermal reactor outlet/SCR inlet high differential pressure - ThR2 *)
	bThr2_AuxGasValve_CtrlBlock : BOOL; (* Th.Reactor aux. gas heating system - ThR2 - aux. gas heating controller block due to valve closed *)
