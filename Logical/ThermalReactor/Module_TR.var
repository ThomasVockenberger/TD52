	MM2VIS : MM2VIS_Struct;
	VIS2MM : VIS2MM_Struct;
	OUT_TR : OUT_TR_Struct;
	ParaFactoryDefault : Para_Struct;
	Para : Para_Struct; (*Parameters*)
	pm : Para_Struct;
	pm1 : PERM_TR_Struct;
	TK_moduleTR : REAL; (* Temp. Reaktionskammer fuer Regelung *)
	TK1 : REAL; (* Temp. Reaktionskammer 1 *)
	TK2 : REAL; (* Temp. Reaktionskammer 2 *)
	xTRW06 : SR; (* Reaktor: Differenz TK1/TK2 max. *)
	xTRW05 : SR; (* Reaktor: Schaltschranktemp. max. *)
	xTRW04 : SR; (* Reaktor: Aufheizzeit ueberschr. *)
	xTRW08 : SR; (* Reaktor: Temp. Reakt.kammer min. *)
	xTRW07 : SR; (* Reaktor: Temp. Reakt.kammer max. *)
	bThR2_T_fault_ReactChamber : BOOL; (* Th.Reactor warning - reactor chamber temperature sensors failure - ThR2 *)
	xTRW02 : SR; (* Reaktor: Stoerung Druckluft *)
	xTRA02 : SR; (* Reaktor: Sicherheitsschleife *)
	xTRA01 : SR; (* Reaktor: Stoerg. Abgaskl. Mitte *)
	xTRW01 : SR; (* Reaktor: Fuehlerbruch *)
	xTRW03 : SR; (* Reaktor: Stoerg. Abgaskl. Ende *)
	xTON_INIT : TON;
	tCtrTR_Heater_In : _tGeACtrIn;
	tCtrTR_Heater_Out : _tGeACtrOut;
