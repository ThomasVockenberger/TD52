	FG_InlVent_Step2_CtrInlLou : BOOL := 0; (*release for fix-speed inlet-fan 2 depending on ctr inlet louver*)
	FG_InlVent_Step1_CtrInlLou : BOOL := 0; (*release for fix-speed inlet-fan 1 depending on ctr inlet louver*)
