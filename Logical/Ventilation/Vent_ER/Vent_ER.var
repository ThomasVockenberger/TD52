VAR
	xTON_purgecycle : TON := (0);
	xGR_MAXR_InlLou2 : GR_MAXR := (0); (*minimum opening position of inlet louver 2 for release FQ room ventilation*)
	xGR_MAXR_InlLou1 : GR_MAXR := (0); (*minimum opening position of inlet louver 1 for release FQ room ventilation*)
	xGR_MAXR_OutlLou1 : GR_MAXR := (0); (*minimum opening position of outlet louver 1 for release FQ room ventilation*)
	xGR_MAXR_OutlLou2 : GR_MAXR := (0); (*minimum opening position of outlet louver 2 for release FQ room ventilation*)
