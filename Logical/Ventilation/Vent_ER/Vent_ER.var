	FG_FU_InlLou_Case21 : BOOL; (*Release FQ roomventilation with controlled inlet louvers and digital feedback signal*)
	FG_FU_InlLou_Case12 : BOOL; (*Release FQ roomventilation with demanded inlet louvers and analog feedback-signal*)
	FG_FU_InlLou_Case11 : BOOL; (*Release FQ roomventilation with demanded inlet louvers and digital feedback-signal*)
	FG_FU_InlLou_Case0 : BOOL; (*Release FQ roomventilation - no inlet louvers control existing*)
	FG_FU_OutlLou_Case22 : BOOL; (*Release FQ roomventilation with controlled outlet louvers and analog feedback signal*)
	FG_FU_OutlLou_Case21 : BOOL; (*Release FQ roomventilation with controlled outlet louvers and digital feedback signal*)
	FG_FU_OutlLou_Case12 : BOOL; (*Release FQ roomventilation with demanded outlet louver and analog feedback-signal*)
	FG_FU_OutlLou_Case11 : BOOL; (*Release FQ roomventilation with demanded outlet louver and digital feedback-signal*)
	FG_FU_OutLou_Case0 : BOOL; (*Release FQ roomventilation - no outlet louvers control existing*)
