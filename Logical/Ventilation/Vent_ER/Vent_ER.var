	bRel_ERV_SafeCheck_Ext : BOOL; (*Extended release conditions for safety plausibility checks *)
	xTOF_EngStop_SafeCheck : TOF; (*Engine stop timer for safety plausibility checks*)
	bERV_SafeCheck_OK : BOOL; (*Safety plausibility checks executed*)
