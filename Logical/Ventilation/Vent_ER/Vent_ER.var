	Release_InlVent_Step2_INT : BOOL := 0; (*general release ventilation step 2 depending on temperature, gas-alarm etc.*)
	Release_InlVent_Step1_INT : BOOL := 0; (*general release ventilation step 1 depending on temperature, gas-alarm etc.*)
