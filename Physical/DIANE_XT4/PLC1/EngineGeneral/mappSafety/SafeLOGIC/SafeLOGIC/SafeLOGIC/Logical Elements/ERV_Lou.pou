FUNCTION_BLOCK ERV_Lou
{ VariableWorksheet := 'Variables' }
﻿{GroupDefinition(0,'Louvre')}

VAR_INPUT {Group(0)}
    {LINE(1)}
    PARA_Lou_Active : SAFEBOOL; (*PARA: Lou existing*)
    {LINE(2)}
    sbColdMode_Active : SAFEBOOL; (*Cold mode is active*)
    {LINE(3)}
    sbN_Standstill : SAFEBOOL; (*Actual engine speed <  80rpm*)
    {LINE(4)}
    sbGasValves_Closed : SAFEBOOL; (*Gasvalves - All closed*)
    {LINE(5)}
    sDI_ERV_Lou_OP : SAFEBOOL; (*DI Engine room ventilation - Louvre opened*)
    {LINE(6)}
    sDI_ERV_Lou_CL : SAFEBOOL; (*DI Engine room ventilation - Louvre closed*)
    {LINE(7)}
    sbSafeInputOK_ERV_Lou_OP : SAFEBOOL; (*Safe input OK - DI Engine room ventilation - Louvre opened*)
    {LINE(8)}
    sbSafeInputOK_ERV_Lou_CL : SAFEBOOL; (*Safe input OK - DI Engine room ventilation - Louvre closed*)
END_VAR

VAR_OUTPUT {Group(0)}
    {LINE(29)}
    bOUT_Lou_OK : BOOL; (*CPU OUT: Engine room ventilation - Louvre OK*)
    {LINE(30)}
    bOUT_Lou_OK_PC : BOOL; (*CPU OUT: Engine room ventilation - Louvre plausibility check OK*)
    {LINE(31)}
    iOUT_Lou_OK_1m_ET : DINT; (*CPU OUT: Engine room ventilation - Louvre not OK - Elipsed time*)
    {LINE(32)}
    bAMM_Lou_OP : BOOL; (*WARNING - Room ventilation failure - Louvre opened signal OK*)
    {LINE(33)}
    bAMM_Lou_CL : BOOL; (*WARNING - Room ventilation failure - Louvre closed signal OK*)
    {LINE(34)}
    bAMM_Lou_OP_NV : BOOL; (*WARNING - Room ventilation failure - Louvre opened signal not valid*)
    {LINE(35)}
    bAMM_Lou_CL_NV : BOOL; (*WARNING - Room ventilation failure - Louvre closed signal not valid*)
    {LINE(36)}
    bAMM_Lou_PC : BOOL; (*WARNING - Room ventilation failure - Louvre plausibility check failure*)
    {LINE(37)}
    sbSL_OK : SAFEBOOL; (*Safety loop OK*)
END_VAR

VAR {Group(0)}
    {LINE(9)}
    sbR_TRIG_Lou_PC_OP : SAFEBOOL; (*R_TRIG: Engine room ventilation - Plausibility check for opening the louvres*)
    {LINE(10)}
    sbR_TRIG_Lou_PC_CL : SAFEBOOL; (*R_TRIG: Engine room ventilation - Plausibility check for closing the louvres*)
    {LINE(11)}
    xET_TOF1 : ELAPSED_TIME_TOF; (*FuB*)
    {LINE(12)}
    xET_TOF2 : ELAPSED_TIME_TOF; (*FuB*)
    {LINE(13)}
    xR_TRIG_1 : R_TRIG; (*FuB*)
    {LINE(14)}
    xR_TRIG_2 : R_TRIG; (*FuB*)
    {LINE(15)}
    xR_TRIG_3 : R_TRIG_S; (*FuB*)
    {LINE(16)}
    xTON_S_1 : TON_S; (*FuB*)
    {LINE(17)}
    xTON_S_2 : TON_S; (*FuB*)
    {LINE(18)}
    xTON_S_3 : TON_S; (*FuB*)
    {LINE(19)}
    xTON_S_4 : TON_S; (*FuB*)
    {LINE(20)}
    xKeepAMM_2s_W1 : KeepAMM_2s; (*FuB*)
    {LINE(21)}
    xDI_MON_ERV_Lou_OP : DI_MON_PARA; (*FuB*)
    {LINE(22)}
    xDI_MON_ERV_Lou_CL : DI_MON_PARA; (*FuB*)
    {LINE(23)}
    xRS_S_1 : RS_S; (*FuB*)
    {LINE(24)}
    xRS_S_2 : RS_S; (*FuB*)
    {LINE(25)}
    xRS_S_3 : RS_S; (*FuB*)
    {LINE(26)}
    sbSL_OK_Lou_OP : SAFEBOOL; (*Safety loop OK - Louvre opened*)
    {LINE(27)}
    sbSL_OK_Lou_CL : SAFEBOOL; (*Safety loop OK - Louvre closed*)
    {LINE(28)}
    sbSL_OK_Lou_PC : SAFEBOOL; (*Safety loop OK - Louvre plausibility check*)
END_VAR

