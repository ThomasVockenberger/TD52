FUNCTION_BLOCK GAS_TRAIN
{ VariableWorksheet := 'Variables' }
﻿{GroupDefinition(0,'GasTrain')}

VAR_INPUT {Group(0)}
    {LINE(1)}
    PARA_GT_Exist : SAFEBOOL; (*PARA: Gas train existing*)
    {LINE(2)}
    sbRel_GV : SAFEBOOL; (*Release gas valve*)
    {LINE(3)}
    bPS_DO_Rel_GVa : BOOL; (*Physical state of output - Release gasvalve a*)
    {LINE(4)}
    bPS_DO_Rel_GVb : BOOL; (*Physical state of output - Release gasvalve b*)
    {LINE(5)}
    sbGas_LC_Triggered : SAFEBOOL; (*Gas leakage ckeck - Triggered*)
    {LINE(6)}
    sDI_GT_SafeDevOK : SAFEBOOL; (*DI Gas safety device - Gastrain OK*)
    {LINE(7)}
    bPS_DO_GT_SafeDev : BOOL; (*Physical state of output - Gas safety device - gastrain*)
    {LINE(8)}
    sbN_Standstill : SAFEBOOL; (*Actual engine speed < 80rpm*)
    {LINE(9)}
    sbSafetyLoop_OK : SAFEBOOL; (*Safety function OK - Safety loop OK*)
    {LINE(10)}
    sbSafeInputOK_SafeDevOK : SAFEBOOL; (*Safe Input is OK*)
    {LINE(11)}
    sbSafeOutputOK_GVa : SAFEBOOL; (*Safe output OK - DO Release gasvalve a*)
    {LINE(12)}
    sbSafeOutputOK_GVb : SAFEBOOL; (*Safe output OK - DO Release gasvalve b*)
    {LINE(13)}
    sbSafeOutputOK_SafeDev : SAFEBOOL; (*Safe output OK - DO Gas safety device - gastrain*)
END_VAR

VAR_OUTPUT {Group(0)}
    {LINE(25)}
    sDO_Rel_GV : SAFEBOOL; (*DO Release gas valve*)
    {LINE(26)}
    bOUT_Rel_GV : BOOL; (*Release gas valve*)
    {LINE(27)}
    bOUT_Rel_GVa_PS : BOOL; (*Release gas valve a - Pysical state*)
    {LINE(28)}
    bOUT_Rel_GVb_PS : BOOL; (*Release gas valve b - Pysical state*)
    {LINE(29)}
    sDO_GT_SafeDevice : SAFEBOOL; (*DO Gas safety device*)
    {LINE(30)}
    bOUT_GT_SD_Dem : BOOL; (*Demand gas safety device*)
    {LINE(31)}
    bOUT_GT_SD_Dem_PS : BOOL; (*Demand gas safety device - Physical state*)
    {LINE(32)}
    iOUT_GT_LC_130s_ET : DINT; (*Gas leakage check 130s - Elipsed time*)
    {LINE(33)}
    bError_GT : BOOL; (*ERROR: Gas train failure*)
    {LINE(34)}
    bWarning_In_SafeDevOK : BOOL; (*WARNING: Gas safety device OK - input not valid*)
    {LINE(35)}
    bWarning_Out_GVa : BOOL; (*WARNING: Release gas valve a - output not valid*)
    {LINE(36)}
    bWarning_Out_GVb : BOOL; (*WARNING: Release gas valve b - output not valid*)
    {LINE(37)}
    bWarning_Out_SafeDev : BOOL; (*WARNING: Gas safety device - output not valid*)
    {LINE(38)}
    bOUT_GT_OK : BOOL; (*Function gas supply interruption OK*)
    {LINE(39)}
    bOUT_DI_GT_SafeDevOK : BOOL; (*Gas safety device OK - Status of digital input*)
END_VAR

VAR {Group(0)}
    {LINE(14)}
    xTP_GT_SD_5s : TP_S; (*FuB*)
    {LINE(15)}
    xR_TRIG_GT_SD : R_TRIG_S; (*FuB*)
    {LINE(16)}
    xTOF_GT_PC_100ms : TOF_S; (*FuB*)
    {LINE(17)}
    xTON_GT_MF_1s : TON_S; (*FuB*)
    {LINE(18)}
    xTON_GT_SD_6s : TON_S; (*FuB*)
    {LINE(19)}
    xET : ELAPSED_TIME; (*FuB*)
    {LINE(20)}
    xKeepAMM_2s_E1 : KeepAMM_2s; (*FuB*)
    {LINE(21)}
    xKeepAMM_2s_W1 : KeepAMM_2s; (*FuB*)
    {LINE(22)}
    xKeepAMM_2s_W2 : KeepAMM_2s; (*FuB*)
    {LINE(23)}
    xKeepAMM_2s_W3 : KeepAMM_2s; (*FuB*)
    {LINE(24)}
    xKeepAMM_2s_W4 : KeepAMM_2s; (*FuB*)
END_VAR

