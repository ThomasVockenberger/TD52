FUNCTION_BLOCK HeatWater
{ VariableWorksheet := 'Variables' }
﻿{GroupDefinition(0,'NewGroup')}

VAR_INPUT {Group(0)}
    {LINE(1)}
    sDI_LS_Lo : SAFEBOOL; (*DI Minimum level switch*)
    {LINE(2)}
    sDI_PS1_Hi : SAFEBOOL; (*DI Maximum pressure switch 1*)
    {LINE(3)}
    sDI_PS2_Hi : SAFEBOOL; (*DI Maximum pressure switch 2*)
    {LINE(4)}
    sDI_PS1_Lo : SAFEBOOL; (*DI Minimum pressure switch 1*)
    {LINE(5)}
    sDI_PS2_Lo : SAFEBOOL; (*DI Minimum pressure switch 2*)
    {LINE(6)}
    sDI_TS1_Hi : SAFEBOOL; (*DI Maximum temperature switch 1*)
    {LINE(7)}
    sDI_TS2_Hi : SAFEBOOL; (*DI Maximum temperature switch 2*)
    {LINE(8)}
    sDI_FS_Lo : SAFEBOOL; (*DI Minimum flow switch*)
    {LINE(9)}
    sbSafeInputOK_LS_Lo : SAFEBOOL; (*Safe input OK - DI Minimum level switch*)
    {LINE(10)}
    sbSafeInputOK_PS1_Hi : SAFEBOOL; (*Safe input OK - DI Maximum pressure switch 1*)
    {LINE(11)}
    sbSafeInputOK_PS2_Hi : SAFEBOOL; (*Safe input OK - DI Maximum pressure switch 2*)
    {LINE(12)}
    sbSafeInputOK_PS1_Lo : SAFEBOOL; (*Safe input OK - DI Minimum pressure switch 1*)
    {LINE(13)}
    sbSafeInputOK_PS2_Lo : SAFEBOOL; (*Safe input OK - DI Minimum pressure switch 2*)
    {LINE(14)}
    sbSafeInputOK_TS1_Hi : SAFEBOOL; (*Safe input OK - DI Maximum temperature switch 1*)
    {LINE(15)}
    sbSafeInputOK_TS2_Hi : SAFEBOOL; (*Safe input OK - DI Maximum temperature switch 2*)
    {LINE(16)}
    sbSafeInputOK_FS_Lo : SAFEBOOL; (*Safe input OK - DI Minimum flow switch*)
    {LINE(17)}
    PARA_LS_Lo_Exist : SAFEBOOL; (*PARA: Minimum level switch available*)
    {LINE(18)}
    PARA_PS1_Hi_Exist : SAFEBOOL; (*PARA: Maximum pressure switch 1 available*)
    {LINE(19)}
    PARA_PS2_Hi_Exist : SAFEBOOL; (*PARA: Maximum pressure switch 2 available*)
    {LINE(20)}
    PARA_PS1_Lo_Exist : SAFEBOOL; (*PARA: Minimum pressure switch 1 available*)
    {LINE(21)}
    PARA_PS2_Lo_Exist : SAFEBOOL; (*PARA: Minimum pressure switch 2 available*)
    {LINE(22)}
    PARA_TS1_Hi_Exist : SAFEBOOL; (*PARA: Maximum temperature switch 1 available*)
    {LINE(23)}
    PARA_TS2_Hi_Exist : SAFEBOOL; (*PARA: Maximum temperature switch 2 available*)
    {LINE(24)}
    PARA_FS_Lo_Exist : SAFEBOOL; (*PARA: Minimum flow switch available*)
    {LINE(25)}
    sbGCB_On_60s : SAFEBOOL; (*Generator circuit breaker ON for 60s*)
    {LINE(26)}
    sbN_Standstill : SAFEBOOL; (*Actual engine speed <  80rpm*)
END_VAR

VAR_OUTPUT {Group(0)}
    {LINE(36)}
    bAMM_LS_Lo : BOOL; (*TRIP - Level minimum*)
    {LINE(37)}
    bAMM_PS1_Hi : BOOL; (*TRIP - Pressure 1 maximum*)
    {LINE(38)}
    bAMM_PS2_Hi : BOOL; (*TRIP - Pressure 2 maximum*)
    {LINE(39)}
    bAMM_PS1_Lo : BOOL; (*TRIP - Pressure 1 minimum*)
    {LINE(40)}
    bAMM_PS2_Lo : BOOL; (*TRIP - Pressure 2 minimum*)
    {LINE(41)}
    bAMM_TS1_Hi : BOOL; (*TRIP - Temperature 1 maximum*)
    {LINE(42)}
    bAMM_TS2_Hi : BOOL; (*TRIP - Temperature 2 maximum*)
    {LINE(43)}
    bAMM_FS_Lo : BOOL; (*TRIP - Flow minimum*)
    {LINE(44)}
    bAMM_LS_Lo_NV : BOOL; (*WARNING - Level minimum - signal not valid*)
    {LINE(45)}
    bAMM_PS1_Hi_NV : BOOL; (*WARNING - Pressure 1 maximum - signal not valid*)
    {LINE(46)}
    bAMM_PS2_Hi_NV : BOOL; (*WARNING - Pressure 2 maximum - signal not valid*)
    {LINE(47)}
    bAMM_PS1_Lo_NV : BOOL; (*WARNING - Pressure 1 minimum - signal not valid*)
    {LINE(48)}
    bAMM_PS2_Lo_NV : BOOL; (*WARNING - Pressure 2 minimum - signal not valid*)
    {LINE(49)}
    bAMM_TS1_Hi_NV : BOOL; (*WARNING - Temperature 1 maximum - signal not valid*)
    {LINE(50)}
    bAMM_TS2_Hi_NV : BOOL; (*WARNING - Temperature 2 maximum - signal not valid*)
    {LINE(51)}
    bAMM_FS_Lo_NV : BOOL; (*WARNING - Flow minimum - signal not valid*)
    {LINE(52)}
    bAMM_FS_Lo_PC : BOOL; (*WARNING - Flow minimum - plausibility check failure*)
    {LINE(53)}
    bOUT_F20_LS_Lo_OK : BOOL; (*CPU OUT: Minimum level switch OK*)
    {LINE(54)}
    bOUT_F20_PS1_Hi_OK : BOOL; (*CPU OUT: Maximum pressure switch 1 OK*)
    {LINE(55)}
    bOUT_F20_PS2_Hi_OK : BOOL; (*CPU OUT: Maximum pressure switch 2 OK*)
    {LINE(56)}
    bOUT_F20_PS1_Lo_OK : BOOL; (*CPU OUT: Minimum pressure switch 1 OK*)
    {LINE(57)}
    bOUT_F20_PS1_Lo_DI : BOOL; (*CPU OUT: Minimum pressure switch 1 - Status of digital input*)
    {LINE(58)}
    bOUT_F20_PS2_Lo_OK : BOOL; (*CPU OUT: Minimum pressure switch 2 OK*)
    {LINE(59)}
    bOUT_F20_PS2_Lo_DI : BOOL; (*CPU OUT: Minimum pressure switch 2 - Status of digital input*)
    {LINE(60)}
    bOUT_F20_TS1_Hi_OK : BOOL; (*CPU OUT: Maximum temperature switch 1 OK*)
    {LINE(61)}
    bOUT_F20_TS2_Hi_OK : BOOL; (*CPU OUT: Maximum temperature switch 2 OK*)
    {LINE(62)}
    bOUT_F20_FS_Lo_OK : BOOL; (*CPU OUT: Minimum flow switch OK*)
    {LINE(63)}
    bOUT_F20_FS_Lo_OK_PC : BOOL; (*CPU OUT: Minimum flow switch plausibility check OK*)
    {LINE(64)}
    bOUT_F20_FS_Lo_DI : BOOL; (*CPU OUT: Minimum flow switch - Status of digital input*)
    {LINE(65)}
    iOUT_F20_PS1_Lo_OK_ET : DINT; (*CPU OUT: Minimum pressure switch 1 OK - Elipsed time*)
    {LINE(66)}
    iOUT_F20_PS2_Lo_OK_ET : DINT; (*CPU OUT: Minimum pressure switch 2 OK - Elipsed time*)
    {LINE(67)}
    iOUT_F20_FS_Lo_OK_ET : DINT; (*CPU OUT: Minimum flow switch OK - Elipsed time*)
    {LINE(68)}
    iOUT_F20_FS_Lo_PC_ET : DINT; (*CPU OUT: Minimum flow switch plausibility check - Elipsed time*)
END_VAR

VAR {Group(0)}
    {LINE(27)}
    xDI_MON_LS_Lo : DI_MON_PARA; (*FuB*)
    {LINE(28)}
    xDI_MON_PS1_Hi : DI_MON_PARA; (*FuB*)
    {LINE(29)}
    xDI_MON_PS2_Hi : DI_MON_PARA; (*FuB*)
    {LINE(30)}
    xHW_MIN_MON_PS1_Lo : HW_MIN_MON; (*FuB*)
    {LINE(31)}
    xHW_MIN_MON_PS2_Lo : HW_MIN_MON; (*FuB*)
    {LINE(32)}
    xDI_MON_TS1_Hi : DI_MON_PARA; (*FuB*)
    {LINE(33)}
    xDI_MON_TS2_Hi : DI_MON_PARA; (*FuB*)
    {LINE(34)}
    xHW_MIN_MON_FS_Lo : HW_MIN_MON; (*FuB*)
    {LINE(35)}
    xPC_FS_Lo : PLAUSIBILITY; (*FuB*)
END_VAR

