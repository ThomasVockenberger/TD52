FUNCTION_BLOCK HeatWaterSys
{ VariableWorksheet := 'Variables' }
﻿{GroupDefinition(0,'NewGroup')}

VAR_INPUT {Group(0)}
    {LINE(1)}
    sbGCB_On_60s : SAFEBOOL; (*Generator circuit breaker ON for 60s*)
    {LINE(2)}
    sbN_Standstill : SAFEBOOL; (*Actual engine speed <  80rpm*)
END_VAR

VAR_OUTPUT {Group(0)}
    {LINE(6)}
    sbF20_OK_HeatWater : SAFEBOOL; (*Safety function 20 OK - Heating water system protection*)
END_VAR

VAR {Group(0)}
    {LINE(3)}
    xDI_MON_HWcirc_Cust : DI_MON_PARA; (*FuB*)
    {LINE(4)}
    xHeatWater_LT : HeatWater; (*FuB*)
    {LINE(5)}
    xHeatWater_HT : HeatWater; (*FuB*)
END_VAR

{ CodeWorksheet := 'HeatWaterSys', Type := '.fbd' }
