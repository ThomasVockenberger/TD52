  <comment localId="1" height="12" width="134">
    <position x="4" y="10" />
    <content>
      <html xmlns="http://www.w3.org/1999/xhtml">
        <head>
          <title />
        </head>
        <body>
          <p style="color:#ff00ff;font-family:Calibri;font-weight:normal;font-style:normal;font-size:16pt;">The camshaft pickup outputs a pulse every 2 rotations.&lt;br /&gt;Therefore the input must be multiplied by 2 to obtain the actual speed.</p>
        </body>
      </html>
    </content>
  </comment>
